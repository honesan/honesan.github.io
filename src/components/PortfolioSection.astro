<style>

.projects-grid{

    display:grid;

    grid-template-columns:1fr;

    justify-items:center;

    margin-top:40px;

}

.project-card{

    width:min(420px,100%);

    display:flex;

    flex-direction:column;

    align-items:center;

    justify-content:center;

    text-align:center;

    padding:32px 24px;

    border:none;

    border-radius:22px;

    background:rgba(0,0,0,.05);

    cursor:pointer;

    transition:
        transform .25s ease,
        box-shadow .25s ease,
        background .25s ease;

}

.project-card:hover{

    transform:translateY(-8px);

    background:rgba(0,0,0,.08);

    box-shadow:
        0 20px 40px rgba(0,0,0,.08);

}

.project-icon{

    width:72px;

    height:72px;

    display:flex;

    align-items:center;

    justify-content:center;

    margin-bottom:20px;

}

.project-icon svg{

    width:64px;

    height:64px;

}
.project-card h3{

    margin:0 0 10px;

    font-size:1.4rem;

    font-weight:600;

}

.project-card p{

    margin:0;

    line-height:1.6;

    opacity:.75;

}

.project-modal{

    border:none;

    border-radius:24px;

    padding:0;

    width:min(700px,90vw);

    max-height:85vh;

    overflow:auto;

    margin:auto;

    position:fixed;

    inset:0;

    box-shadow:
        0 30px 70px rgba(0,0,0,.25);

}

.project-modal::backdrop{

    background:rgba(0,0,0,.45);

    backdrop-filter:blur(6px);

}

.modal-content{

    position:relative;

    padding:40px;

    cursor:default;

}

.modal-content h2{

    text-align:center;

    margin-bottom:24px;

    font-size:2rem;

}

.modal-content h3{

    margin-top:24px;

    margin-bottom:10px;

    font-size:1.25rem;

}

.modal-content p{

    margin-bottom:14px;

    line-height:1.8;

}

.project-list{

    margin:0 0 16px;

    padding-left:22px;

    line-height:1.8;

}

.project-list li{

    margin-bottom:6px;

}

.close-modal{

    position:absolute;

    top:16px;

    right:16px;

    width:40px;

    height:40px;

    border:none;

    border-radius:50%;

    background:#111;

    color:#fff;

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:22px;

    cursor:pointer;

    transition:
        transform .2s ease,
        background .2s ease;

}

.close-modal:hover{

    transform:scale(1.08);

    background:#333;

}

@media (max-width:700px){

    .project-card{

        width:100%;

        padding:24px 20px;

    }

    .project-icon{

        width:56px;

        height:56px;

    }

    .project-icon svg{

        width:48px;

