---
import "@styles/_variables.css";
import "@styles/_reset.css";
import "@styles/global.css";

import { Font } from "astro:assets";
import { SITE, SOCIALS } from "@consts";
import { ClientRouter } from "astro:transitions";
import Header from "components/Header.astro";
import Footer from "@components/Footer.astro";

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const {
    companyName = "Honesan",
    legalName = SITE.LEGAL_NAME,
    title = "Honesan",
    description =
        "Honesan creates thoughtful spaces with modern design and personalized interiors.",
    canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
    ogImage = SITE.OG_IMAGE,
    twitterHandle = SITE.TWITTER?.CREATOR,
} = Astro.props;

const socialImageURL = new URL(
    ogImage ?? SITE.OG_IMAGE ?? "og-image.webp",
    Astro.url.origin,
).href;

const schemaData = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${title}`,
    url: `${canonicalURL}`,
    description: `${description}`,
    isPartOf: {
        "@type": "WebSite",
        name: `${companyName}`,
        url: `${canonicalURL}`,
        publisher: {
            "@type": "Organization",
            name: `${companyName}`,
            legalName: legalName,
            url: `${canonicalURL}`,
            "@id": `${canonicalURL}`,
            sameAs: SOCIALS.map((social) => social.HREF),
        },
    },
};
---

<!doctype html>
<html lang={SITE.LOCALE ?? "en"}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />

        <title>{title}</title>

        <meta
            name="description"
            content={description}
        />

        <meta name="author" content="Honesan" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <link
            rel="canonical"
            href={canonicalURL}
        />

        <link
            rel="preconnect"
            href="https://res.cloudinary.com"
            crossorigin
        />

        <link
            rel="preload"
            as="image"
            href="/hero-video-poster.webp"
            fetchpriority="high"
        />

        <Font cssVariable="--font-dm-sans" />

        <meta property="og:title" content={title} />

        <meta
            property="og:description"
            content={description}
        />

        <meta
            property="og:image"
            content={socialImageURL}
        />

        <meta
            property="og:type"
            content="website"
        />

        {twitterHandle && (
            <meta
                name="twitter:creator"
                content={twitterHandle}
            />
        )}

        {googleSiteVerification && (
            <meta
                name="google-site-verification"
                content={googleSiteVerification}
            />
        )}

        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData)}
        />

        <ClientRouter />
    </head>

    <body>
        <Header />

        <main>
            <slot />
        </main>

        <Footer />
    </body>
</html>